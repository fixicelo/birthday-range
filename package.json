{
  "name": "birthday-range",
  "version": "1.2.0",
  "description": "Calculate possible birthday ranges from partial info",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "docs:build": "typedoc"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "birthday",
    "dob",
    "birthdate",
    "temporal",
    "zodiac",
    "age"
  ],
  "author": "fixicelo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fixicelo/birthday-range.git"
  },
  "bugs": {
    "url": "https://github.com/fixicelo/birthday-range/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "temporal-polyfill": "^1.0.1",
    "zodiac-mapper": "^0.2.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.9",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
